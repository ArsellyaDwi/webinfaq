generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_M2tms@epipFRzu8-long-dew-ainutjic-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require"
}

model User {
  username  String   @id
  name      String
  password  String
  major     String
  batch     String
  phone     String?
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Donation {
  id          String   @id
  name        String
  batch       String
  major       String
  amount      Int
  date        String
  phone       String?
  wishes      String?
  proofImage  String?
  username    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id          String   @id
  title       String
  imageUrl    String   @map("image_url")
  date        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("activities")
}

model QrisConfig {
  nominal   Int      @id
  imageUrl  String   @map("image_url")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("qris_configs")
}
